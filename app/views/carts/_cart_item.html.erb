<tr id="cart_item_<%= item.id %>" class="hover:bg-gray-50">
  <td class="px-6 py-4">
    <div class="flex items-center gap-4">
      <% if item.product.images.attached? %>
        <%= image_tag item.product.images.first, class: "w-16 h-16 object-cover rounded", alt: item.product.name %>
      <% else %>
        <div class="w-16 h-16 bg-gray-200 rounded flex items-center justify-center">
          <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      <% end %>
      <div>
        <%= link_to item.product.name, product_path(item.product), class: "font-medium text-gray-900 hover:text-blue-600" %>
        <% if item.reservation_expired? %>
          <p class="text-xs text-red-600 mt-1">Reservation expired</p>
        <% else %>
          <p class="text-xs text-gray-500 mt-1">
            Reserved until <%= item.reserved_until.strftime("%I:%M %p") %>
          </p>
        <% end %>
      </div>
    </div>
  </td>
  <td class="px-6 py-4 text-gray-900">
    $<%= number_with_precision(item.product.price, precision: 2) %>
  </td>
  <td class="px-6 py-4">
    <%= form_with model: item, url: cart_item_path(item), method: :patch, class: "flex items-center gap-2" do |f| %>
      <%= f.number_field :quantity, min: 1, max: item.product.available_quantity + item.quantity, value: item.quantity, class: "w-20 border border-gray-300 rounded px-2 py-1 text-center" %>
      <%= f.submit "Update", class: "text-sm bg-gray-100 hover:bg-gray-200 px-3 py-1 rounded" %>
    <% end %>
  </td>
  <td class="px-6 py-4 font-semibold text-gray-900">
    $<%= number_with_precision(item.subtotal, precision: 2) %>
  </td>
  <td class="px-6 py-4">
    <%= button_to cart_item_path(item), method: :delete, class: "text-red-600 hover:text-red-800", data: { turbo_confirm: "Remove item from cart?" } do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
    <% end %>
  </td>
</tr>
