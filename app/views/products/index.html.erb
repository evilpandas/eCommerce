<p style="color: green"><%= notice %></p>

<% content_for :title, "Products" %>

<h1>Products</h1>

<div id="products" class="grid grid-cols-4 place-items-center">
  <% @products.each do |product| %>
    <div class="group my-10 flex w-full max-w-xs flex-col overflow-hidden rounded-lg border border-gray-100 bg-white shadow-md">
    <div id="carousel-<%= product.id %>" class="relative mx-3 mt-3 h-60 overflow-hidden rounded-xl" data-carousel="static">
      <!-- Carousel wrapper -->
      <div class="relative h-full w-full">
        <% if product.images.attached? %>
          <% product.images.each_with_index do |image, index| %>
            <div class="absolute inset-0 duration-700 ease-in-out <%= 'hidden' unless index == 0 %>" data-carousel-item="<%= index == 0 ? 'active' : '' %>">
              <%= link_to product_path(product), class: "block h-full w-full" do %>
                <%= image_tag image, class: "h-full w-full object-cover", alt: "product image #{index + 1}" %>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="absolute inset-0 duration-700 ease-in-out" data-carousel-item="active">
            <%= link_to product_path(product), class: "block h-full w-full" do %>
              <img class="h-full w-full object-cover" src="https://images.unsplash.com/flagged/photo-1556637640-2c80d3201be8?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxzZWFyY2h8M3x8c25lYWtlcnxlbnwwfHwwfHw%3D&auto=format&fit=crop&w=500&q=60" alt="product image" />
            <% end %>
          </div>
        <% end %>
      </div>

      <% if product.images.attached? && product.images.count > 1 %>
        <!-- Slider controls -->
        <button type="button" class="absolute top-0 start-0 z-30 flex items-center justify-center h-full px-2 cursor-pointer group focus:outline-none" data-carousel-prev>
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-white/30 group-hover:bg-white/50 group-focus:ring-2 group-focus:ring-white">
            <svg class="w-3 h-3 text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 1 1 5l4 4"/>
            </svg>
            <span class="sr-only">Previous</span>
          </span>
        </button>
        <button type="button" class="absolute top-0 end-0 z-30 flex items-center justify-center h-full px-2 cursor-pointer group focus:outline-none" data-carousel-next>
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-white/30 group-hover:bg-white/50 group-focus:ring-2 group-focus:ring-white">
            <svg class="w-3 h-3 text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="sr-only">Next</span>
          </span>
        </button>

      <% end %>
    </div>
    <div class="mt-4 px-5 pb-5">
      <%= link_to product_path(product) do %>
        <h5 class="text-xl tracking-tight text-slate-900"><%= product.name %></h5>
      <% end %>
      <div class="mt-2 mb-5 flex items-center justify-between">
        <p>
          <% if product.price.present? %>
            <span class="text-3xl font-bold text-slate-900">$<%= number_with_precision(product.price, precision: 2) %></span>
            <span class="text-sm text-slate-900 line-through">$<%= number_with_precision(product.price * 1.2, precision: 2) %></span><br />
          <% else %>
            <span class="text-3xl font-bold text-slate-900">Price TBD</span><br />
          <% end %>
          <% if product.description.present? %>
            <span class="text-sm text-slate-900"><%= product.description.truncate(60) %></span>
          <% end %>
        </p>
      </div>
      <%= link_to product_path(product), class: "flex items-center justify-center rounded-md bg-slate-900 px-5 py-2.5 text-center text-sm font-medium text-white hover:bg-gray-700 focus:outline-none focus:ring-4 focus:ring-blue-300" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="mr-2 h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        View Product
      <% end %>
    </div>
  </div>
  
  <% end %>
</div>

