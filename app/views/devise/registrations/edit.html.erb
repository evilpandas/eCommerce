<div class="min-h-screen bg-gray-50 py-12 px-4 sm:px-6 lg:px-8 mt-16">
  <div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-lg shadow-md p-8">
      <h2 class="text-3xl font-extrabold text-gray-900 mb-2">
        Edit Account
      </h2>
      <p class="text-sm text-gray-600 mb-8">
        Update your account information and password
      </p>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, "Email address", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition", placeholder: "you@example.com" %>
          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <p class="mt-2 text-sm text-amber-600">Currently waiting confirmation for: <%= resource.unconfirmed_email %></p>
          <% end %>
        </div>

        <div class="border-t border-gray-200 pt-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Change Password</h3>
          <p class="text-sm text-gray-500 mb-4">Leave blank if you don't want to change it</p>

          <div class="space-y-4">
            <div>
              <%= f.label :password, "New password", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= f.password_field :password, autocomplete: "new-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition", placeholder: "••••••••" %>
              <% if @minimum_password_length %>
                <p class="text-xs text-gray-500 mt-1"><%= @minimum_password_length %> characters minimum</p>
              <% end %>
            </div>

            <div>
              <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition", placeholder: "••••••••" %>
            </div>
          </div>
        </div>

        <div class="border-t border-gray-200 pt-6">
          <%= f.label :current_password, "Current password", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <p class="text-xs text-gray-500 mb-2">We need your current password to confirm your changes</p>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition", placeholder: "••••••••" %>
        </div>

        <div class="flex items-center justify-between pt-4 border-t border-gray-200">
          <%= link_to :back, class: "text-gray-600 hover:text-gray-800 flex items-center gap-2" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Back
          <% end %>

          <%= f.submit "Update Account", class: "bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 font-medium transition cursor-pointer" %>
        </div>
      <% end %>

      <div class="border-t border-gray-200 mt-8 pt-8">
        <h3 class="text-lg font-medium text-red-900 mb-2">Delete Account</h3>
        <p class="text-sm text-gray-600 mb-4">Once you delete your account, there is no going back. Please be certain.</p>
        <%= button_to "Delete My Account", registration_path(resource_name), method: :delete, data: { turbo_confirm: "Are you sure you want to delete your account? This action cannot be undone." }, class: "bg-red-600 text-white px-6 py-2 rounded-lg hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 font-medium transition cursor-pointer" %>
      </div>
    </div>
  </div>
</div>
